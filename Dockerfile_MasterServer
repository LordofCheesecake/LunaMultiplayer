# syntax=docker/dockerfile:1.7
#
# LunaMultiplayer master-server image. Build/run recipes live in DOCKER.md.
# Multi-arch: linux/amd64, linux/arm64, linux/arm/v7.

ARG DOTNET_SDK_VERSION=10.0-alpine
# `-extra` variant ships ICU + tzdata. The master server runs country-code
# lookups via ICU and the plain `10.0-alpine` is globalization-invariant.
ARG DOTNET_RUNTIME_VERSION=10.0-alpine-extra

################################################################################
# Stage: restore
################################################################################
FROM --platform=$BUILDPLATFORM mcr.microsoft.com/dotnet/sdk:${DOTNET_SDK_VERSION} AS restore
WORKDIR /src

ENV DOTNET_NOLOGO=1 \
    DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_GENERATE_ASPNET_CERTIFICATE=false \
    NUGET_XMLDOC_MODE=skip

# MasterServer's project graph.
COPY .nuget                                 .nuget
COPY LunaMultiPlayer.sln                    LunaMultiPlayer.sln
COPY LmpCommon/LmpCommon.csproj             LmpCommon/LmpCommon.csproj
COPY LmpGlobal/LmpGlobal.csproj             LmpGlobal/LmpGlobal.csproj
COPY Lidgren/Lidgren.projitems              Lidgren/Lidgren.projitems
COPY Lidgren.Core/Lidgren.Core.csproj       Lidgren.Core/Lidgren.Core.csproj
COPY Lidgren.Net/Lidgren.Net.csproj         Lidgren.Net/Lidgren.Net.csproj
COPY uhttpsharp/uhttpsharp.csproj           uhttpsharp/uhttpsharp.csproj
COPY uhttpsharp/packages.config             uhttpsharp/packages.config
COPY LmpUpdater/LmpUpdater.csproj           LmpUpdater/LmpUpdater.csproj
COPY LmpMasterServer/LmpMasterServer.csproj LmpMasterServer/LmpMasterServer.csproj
COPY MasterServer/MasterServer.csproj       MasterServer/MasterServer.csproj

ARG TARGETARCH
ARG TARGETVARIANT

RUN --mount=type=cache,target=/root/.nuget/packages,sharing=locked \
    set -eux; \
    case "${TARGETARCH}" in \
      amd64) RID=linux-musl-x64 ;; \
      arm64) RID=linux-musl-arm64 ;; \
      arm)   RID=linux-musl-arm ;; \
      *)     echo "Unsupported TARGETARCH=${TARGETARCH}"; exit 1 ;; \
    esac; \
    echo "${RID}" > /tmp/rid; \
    dotnet restore MasterServer/MasterServer.csproj -r "${RID}"

################################################################################
# Stage: build
################################################################################
FROM restore AS build
WORKDIR /src

COPY . .

ARG TARGETARCH
ARG TARGETVARIANT

# Trimming deliberately off: shared libraries target netstandard2.0 and
# publish-trim emits NETSDK1124 against them.
RUN --mount=type=cache,target=/root/.nuget/packages,sharing=locked \
    set -eux; \
    RID="$(cat /tmp/rid)"; \
    dotnet publish MasterServer/MasterServer.csproj \
      -c Release \
      -r "${RID}" \
      --self-contained true \
      --no-restore \
      -p:DebugType=embedded \
      -o /publish

################################################################################
# Stage: runtime
# icu-data-full is required to cross-reference country codes in server-list
# filtering; icu-libs ships the library but not the full locale data.
################################################################################
FROM mcr.microsoft.com/dotnet/runtime-deps:${DOTNET_RUNTIME_VERSION} AS runtime

# `-extra` base already ships ICU + tzdata. `icu-data-full` is a separate
# package for the complete locale data set (needed for country-code lookups);
# install alongside the base upgrade.
RUN apk add --no-cache icu-data-full \
 && apk upgrade --no-cache

ARG LMP_UID=1000
ARG LMP_GID=1000
RUN addgroup -g ${LMP_GID} -S lmp \
 && adduser  -u ${LMP_UID} -G lmp -S -h /LmpMasterServer lmp

WORKDIR /LmpMasterServer
COPY --from=build --chown=lmp:lmp /publish/ /LmpMasterServer/

ENV DOTNET_NOLOGO=1 \
    DOTNET_CLI_TELEMETRY_OPTOUT=1 \
    DOTNET_EnableDiagnostics=0 \
    DOTNET_gcServer=1 \
    DOTNET_SYSTEM_GLOBALIZATION_INVARIANT=false \
    ASPNETCORE_URLS=

USER lmp:lmp

EXPOSE 8700/udp 8701/tcp

STOPSIGNAL SIGINT

HEALTHCHECK --interval=30s --timeout=5s --start-period=20s --retries=3 \
  CMD wget --quiet --tries=1 --spider http://127.0.0.1:8701/ || exit 1

CMD ["./MasterServer"]

LABEL org.opencontainers.image.title="LunaMultiplayer Master Server" \
      org.opencontainers.image.description="Server discovery/relay for the LunaMultiplayer federation" \
      org.opencontainers.image.source="https://github.com/LunaMultiplayer/LunaMultiplayer" \
      org.opencontainers.image.licenses="MIT" \
      org.opencontainers.image.vendor="LunaMultiplayer"
